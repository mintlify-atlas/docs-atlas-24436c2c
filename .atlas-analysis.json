  "keyFeatures": [
    "Store production data (projects, shots, assets, tasks)",
    "Track artist progress and task assignments",
    "Version control for preview files",
    "File tree management and path generation",
    "CSV import/export capabilities",
    "Real-time event stream for synchronization",
    "Authentication with JWT tokens",
    "Role-based permissions system",
    "Search and indexing with Meilisearch",
    "Plugin system for extensibility"
  ],
